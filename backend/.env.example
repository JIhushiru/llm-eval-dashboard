# EvalForge backend configuration. Copy to .env and fill in what you need.

# API keys (a provider is "available" only when its key is set)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Ollama server (availability is probed at request time)
OLLAMA_BASE_URL=http://localhost:11434

# SQLite database file
EVALFORGE_DB_PATH=./evalforge.db

# Default judge model ("provider:model")
DEFAULT_JUDGE_MODEL=anthropic:claude-opus-4-8

# Token caps
GENERATION_MAX_TOKENS=1024
JUDGE_MAX_TOKENS=1024

# --- Optional hardening (all off/relaxed by default) ---

# Shared bearer-token gate. Empty = open API (original local-tool behavior).
# When set, every /api request except /api/health must send
# `Authorization: Bearer <token>` (export links accept ?token=<token>).
# The frontend must be built with a matching NEXT_PUBLIC_API_TOKEN.
EVALFORGE_API_TOKEN=

# Per-client (bearer token, else IP) request cap over a 60s window. 0 disables.
EVALFORGE_RATE_LIMIT_PER_MINUTE=120

# When true, startup runs Alembic migrations (`upgrade head`) instead of
# create_all. Leave false for zero-config local dev.
EVALFORGE_USE_MIGRATIONS=false
