# EvalForge backend configuration. Copy to .env and fill in what you need.

# API keys (a provider is "available" only when its key is set)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Ollama server (availability is probed at request time)
OLLAMA_BASE_URL=http://localhost:11434

# SQLite database file
EVALFORGE_DB_PATH=./evalforge.db

# Default judge model ("provider:model")
DEFAULT_JUDGE_MODEL=anthropic:claude-opus-4-8

# Token caps
GENERATION_MAX_TOKENS=1024
JUDGE_MAX_TOKENS=1024
